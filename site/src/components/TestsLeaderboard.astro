---
import {
  aggregateRun,
  formatPercent,
  formatTokens,
  sortRunsByPassRate,
  type EvalResults,
} from "../lib/types"

interface Props {
  results: EvalResults
}

const { results } = Astro.props
const runs = sortRunsByPassRate(results.runs)
---

<table class="leaderboard">
  <thead>
    <tr>
      <th>Model</th>
      <th>Pass rate</th>
      <th class="num">Tests</th>
      <th class="num">Avg tokens</th>
    </tr>
  </thead>
  <tbody>
    {
      runs.map((run) => {
        const agg = aggregateRun(run)
        return (
          <tr>
            <td>{run.provider_id}</td>
            <td>
              <span class="rate-bar">
                <span class="rate-bar-track">
                  <span
                    class="rate-bar-fill"
                    style={`width: ${(agg.passRate ?? 0) * 100}%`}
                  />
                </span>
                {formatPercent(agg.passRate)}
              </span>
            </td>
            <td class="num">{agg.total}</td>
            <td class="num">{formatTokens(agg.avgOutputTokens)}</td>
          </tr>
        )
      })
    }
  </tbody>
</table>
