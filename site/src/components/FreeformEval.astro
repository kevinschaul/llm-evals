---
import OutputCompare from "../islands/OutputCompare"

interface Props {
  dataUrl: string
}

const { dataUrl } = Astro.props
---

<h2>Outputs</h2>
<p style="font-size: 0.85em; color: var(--muted)">
  These outputs need human eyes — read them side by side.
</p>
<OutputCompare client:visible url={dataUrl} />
