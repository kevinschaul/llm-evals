---
import {
  aggregateRun,
  formatDuration,
  formatTokens,
  type EvalResults,
} from "../lib/types"
import ResultsByTest from "../islands/ResultsByTest"

interface Props {
  results: EvalResults
  dataUrl: string
}

const { results, dataUrl } = Astro.props

// No trustworthy score here, so no ranking — just who ran, alphabetically
const runs = [...results.runs].sort((a, b) =>
  a.provider_id.localeCompare(b.provider_id),
)
---

<h2>Models</h2>
<table class="leaderboard">
  <thead>
    <tr>
      <th>Model</th>
      <th class="num">Prompts</th>
      <th class="num">Avg tokens</th>
      <th class="num">Avg time</th>
    </tr>
  </thead>
  <tbody>
    {
      runs.map((run) => {
        const agg = aggregateRun(run)
        return (
          <tr>
            <td>{run.provider_id}</td>
            <td class="num">{run.samples.length}</td>
            <td class="num">{formatTokens(agg.avgOutputTokens)}</td>
            <td class="num">{formatDuration(agg.avgDurationMs)}</td>
          </tr>
        )
      })
    }
  </tbody>
</table>

<h2>Outputs</h2>
<p style="font-size: 0.85em; color: var(--muted)">
  These outputs need human eyes — open a prompt to read them side by side.
</p>
<ResultsByTest client:visible url={dataUrl} />
