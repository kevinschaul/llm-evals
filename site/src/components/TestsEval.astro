---
import {
  aggregateRun,
  formatDuration,
  formatPercent,
  sortRunsByPassRate,
  type EvalResults,
} from "../lib/types"
import ResultsByTest from "../islands/ResultsByTest"

interface Props {
  results: EvalResults
  dataUrl: string
}

const { results, dataUrl } = Astro.props
const runs = sortRunsByPassRate(results.runs)
---

<h2>Leaderboard</h2>
<table class="leaderboard">
  <thead>
    <tr>
      <th>Model</th>
      <th>Pass rate</th>
      <th class="num">Tests</th>
      <th class="num">Avg time</th>
    </tr>
  </thead>
  <tbody>
    {
      runs.map((run) => {
        const agg = aggregateRun(run)
        return (
          <tr>
            <td>{run.provider_id}</td>
            <td>
              <span class="rate-bar">
                <span class="rate-bar-track">
                  <span
                    class="rate-bar-fill"
                    style={`width: ${(agg.passRate ?? 0) * 100}%`}
                  />
                </span>
                {formatPercent(agg.passRate)}
              </span>
            </td>
            <td class="num">{agg.total}</td>
            <td class="num">{formatDuration(agg.avgDurationMs)}</td>
          </tr>
        )
      })
    }
  </tbody>
</table>

{
  results.tests.length > 25 ? (
    // Big batteries are about the leaderboard; individual results stay
    // out of the way (and unfetched) until someone asks
    <details class="test-browse">
      <summary>Browse individual results ({results.tests.length} tests)</summary>
      <p style="font-size: 0.85em; color: var(--muted)">
        Hardest tests first. Each dot is one model, in leaderboard order —
        open a test to read every model's output, failures up top.
      </p>
      <ResultsByTest client:visible url={dataUrl} />
    </details>
  ) : (
    <>
      <h2>Results by test</h2>
      <p style="font-size: 0.85em; color: var(--muted)">
        Hardest tests first, failures up top — the automated scoring here is
        rough, so read the outputs yourself.
      </p>
      <ResultsByTest client:visible url={dataUrl} />
    </>
  )
}
