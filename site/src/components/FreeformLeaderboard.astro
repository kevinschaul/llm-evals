---
import { aggregateRun, formatTokens, type EvalResults } from "../lib/types"

interface Props {
  results: EvalResults
}

const { results } = Astro.props

// No trustworthy score here, so no ranking — just who ran, alphabetically
const runs = [...results.runs].sort((a, b) =>
  a.provider_id.localeCompare(b.provider_id),
)
---

<table class="leaderboard">
  <thead>
    <tr>
      <th>Model</th>
      <th class="num">Prompts</th>
      <th class="num">Avg tokens</th>
    </tr>
  </thead>
  <tbody>
    {
      runs.map((run) => (
        <tr>
          <td>{run.provider_id}</td>
          <td class="num">{run.samples.length}</td>
          <td class="num">{formatTokens(aggregateRun(run).avgOutputTokens)}</td>
        </tr>
      ))
    }
  </tbody>
</table>
