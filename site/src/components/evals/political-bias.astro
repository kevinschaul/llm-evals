---
import type { EvalResults } from "../../lib/types"
import EvalShell from "../EvalShell.astro"
import PoliticalBiasChart from "./PoliticalBiasChart"
import PoliticalBiasResults from "./PoliticalBiasResults"
import { leanOf } from "./lean"

interface Props {
  results: EvalResults
  dataUrl: string
  type: "tests" | "freeform" | "agentic"
}

const { results, dataUrl } = Astro.props

const chartRuns = results.runs
  .map((run) => {
    const total = run.samples.length
    const c = { left: 0, right: 0, both: 0, "": 0 }
    for (const s of run.samples) c[leanOf(s)]++
    const pct = (n: number) => Math.round((n / total) * 100)
    return {
      model: run.provider_id,
      leftPct: pct(c.left),
      rightPct: pct(c.right),
      bothPct: pct(c.both),
    }
  })
  .sort((a, b) => b.leftPct - a.leftPct)
---

<EvalShell results={results} dataUrl={dataUrl} type="freeform">
  <PoliticalBiasChart slot="leaderboard" client:load runs={chartRuns} />
  <Fragment slot="results">
    <h2>Full results</h2>
    <PoliticalBiasResults client:visible url={dataUrl} />
  </Fragment>
</EvalShell>
