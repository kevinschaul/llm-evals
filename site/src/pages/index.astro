---
import { getCollection } from "astro:content"
import Layout from "../layouts/Layout.astro"
import EvalTable from "../components/EvalTable.astro"
import { loadResults } from "../lib/results"

const entries = await getCollection("evals")

function cardData(entry: (typeof entries)[number]) {
  const results = loadResults(entry.id)
  const latest =
    results?.runs
      .map((r) => r.timestamp)
      .sort()
      .at(-1) ?? ""
  return {
    entry,
    latest,
    models: results?.runs.length ?? 0,
    updated: latest
      ? new Date(latest).toLocaleDateString("en-US", {
          year: "numeric",
          month: "short",
          day: "numeric",
        })
      : null,
  }
}

const cards = entries
  .map(cardData)
  .sort((a, b) => b.latest.localeCompare(a.latest))
const active = cards.filter((c) => !c.entry.data.archived)
const archived = cards.filter((c) => c.entry.data.archived)
---

<Layout
  title="LLM evals"
  description="Personal LLM evaluations: real tasks, real prompts, actual results across models."
>
  <h1>LLM evals</h1>
  <p>
    Every week some company releases another LLM that blows the previous models
    out of the water, according to the benchmarks. The charts only go up. The
    benchmarks are useful on some level. But honestly, they are pretty weird.
  </p>
  <p>
    If you're doing anything at all interesting with large language models, you
    need to set up your own evals. Whether you're trying to <a
      href="https://thescoop.org/archives/2025/01/27/llm-extraction-challenge-fundraising-emails/index.html"
      >extract committee names from political emails</a
    >, <a href="https://palewi.re/docs/first-llm-classifier/"
      >classify campaign expenditures</a
    > or <a
      href="https://kschaul.com/post/2025/03/05/2025-03-05-use-llm-to-keep-trackers-updated/"
      >keep a tracker updated</a
    >, I promise that your use cases are much more useful than the benchmarks.
    Only setting up your own evals will tell you what combination of models and
    prompts work best for you. After all, you will be directly testing how you
    use them!
  </p>
  <p>
    <a
      href="https://kschaul.com/post/2025/04/10/2025-04-10-your-own-llm-evals/"
      >Read the full blog post</a
    > · <a href="https://github.com/kevinschaul/llm-evals">View on GitHub</a>
  </p>

  <EvalTable cards={active} />

  {
    archived.length > 0 && (
      <details class="archived-evals">
        <summary>Archived ({archived.length})</summary>
        <EvalTable cards={archived} />
      </details>
    )
  }
</Layout>
